{
  "name": "deprem-market-backend",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build",
    "start": "medusa start",
    "dev": "medusa develop",
    "db:generate": "medusa db:generate",
    "db:migrate": "medusa db:migrate",
    "seed": "medusa exec medusa-config.ts -- node node_modules/@medusajs/medusa/dist/commands/seed.js --seed-file=./src/scripts/seed.ts",
    "setup:cargo": "medusa exec ./src/scripts/setup-cargo.ts",
    "setup:inventory": "medusa exec ./src/scripts/setup-inventory.ts",
    "setup:returns": "medusa exec ./src/scripts/setup-returns.ts",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/admin-shared": "2.15.5",
    "@medusajs/cache-redis": "^2.15.5",
    "@medusajs/caching": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/dashboard": "2.15.5",
    "@medusajs/draft-order": "2.15.5",
    "@medusajs/event-bus-redis": "^2.15.5",
    "@medusajs/file-s3": "^2.15.5",
    "@medusajs/framework": "2.15.5",
    "@medusajs/fulfillment-manual": "^2.15.5",
    "@medusajs/medusa": "2.15.5",
    "@medusajs/ui": "4.1.15",
    "@medusajs/workflow-engine-redis": "^2.15.5",
    "@tanstack/react-query": "5.64.2",
    "nodemailer": "^8.0.10",
    "react-i18next": "13.5.0",
    "react-router-dom": "6.30.3",
    "sharp": "^0.34.5",
    "zod": "4.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.15.5",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.14.1"
}
