# Medusa Backend Environment Configuration
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=backend/apps/storefront

# CORS Configurations
STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,https://docs.medusajs.com

# Services URLs
REDIS_URL=redis://localhost:6375
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5435/medusa

# Security Secrets
JWT_SECRET=supersecret_jwt_key
COOKIE_SECRET=supersecret_cookie_key
AUTH_MFA_ENCRYPTION_KEY=5259f3806c64b952984ea45bc53d26a2af36e2877fad66ab1721ab4ba5624c38

# Google OAuth Credentials (for Production Social Login)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:9000/auth/customer/google/callback

# Default Admin Credentials
ADMIN_EMAIL=admin@medusa-test.com
ADMIN_PASSWORD=supersecret
