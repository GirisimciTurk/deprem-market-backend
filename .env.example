# Medusa Backend Environment Configuration
MEDUSA_ADMIN_ONBOARDING_TYPE=nextjs
MEDUSA_ADMIN_ONBOARDING_NEXTJS_DIRECTORY=backend/apps/storefront

# CORS Configurations (comma-separated; list ONLY your own trusted origins)
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# Services URLs
REDIS_URL=redis://localhost:6375
DATABASE_URL=postgresql://USER:STRONG_PASSWORD@localhost:5435/medusa

# Public-facing URLs of the other two apps (used in callbacks & redirects)
BACKEND_URL=http://localhost:9000
STOREFRONT_URL=http://localhost:8000

# Security Secrets
# Generate strong, unique values per environment, e.g.:
#   JWT_SECRET=$(openssl rand -hex 32)
#   COOKIE_SECRET=$(openssl rand -hex 32)
#   AUTH_MFA_ENCRYPTION_KEY=$(openssl rand -hex 32)
# NEVER commit real secret values to git.
JWT_SECRET=
COOKIE_SECRET=
AUTH_MFA_ENCRYPTION_KEY=

# Google OAuth Credentials (for Production Social Login)
# Create credentials at https://console.cloud.google.com/apis/credentials and set
# the Authorized redirect URI to the STOREFRONT callback page below.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:8000/tr/account/google-callback

# Default Admin Credentials (use a strong password; rotate after first login)
ADMIN_EMAIL=admin@medusa-test.com
ADMIN_PASSWORD=

# Custom admin panel URL (used in password-reset email links)
ADMIN_PANEL_URL=http://localhost:5173

# Paynkolay (VPOS) payment secrets.
# Dev: OPTIONAL (falls back to Paynkolay's public test merchant).
# Production: REQUIRED — config fails closed if any of SX/SECRET_KEY/AGENT_CODE is missing.
PAYNKOLAY_SX=
PAYNKOLAY_CANCEL_SX=
PAYNKOLAY_SECRET_KEY=
PAYNKOLAY_AGENT_CODE=
PAYNKOLAY_SUCCESS_URL=
PAYNKOLAY_FAIL_URL=

# SMTP (optional) — if set, transactional emails are sent; otherwise previews are
# written to sent-emails/. Required for password-reset emails to actually deliver.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Web Push (VAPID) — anahtarları `npx web-push generate-vapid-keys` ile üretin
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:info@example.com

# ── PayTR Pazaryeri (sub-merchant + escrow) ──────────────────────────────────
# PayTR Pazaryeri (Marketplace / Platform Transfer) hesabı gerekir; normal PayTR
# hesabı yetmez. Mağaza panelinden alınır. Production'da ZORUNLU (yoksa fail-closed).
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# "1" = test modu (gerçek para çekilmez), "0" = canlı. Dev varsayılanı 1, prod 0.
PAYTR_TEST_MODE=1
# Opsiyonel override'lar (varsayılanlar BACKEND_URL/STOREFRONT_URL'den türetilir):
# PAYTR_CALLBACK_URL=https://api.depremtek.market/paytr-callback
# PAYTR_OK_URL=https://depremtek.market/tr/odeme/sonuc?status=success
# PAYTR_FAIL_URL=https://depremtek.market/tr/odeme/sonuc?status=fail
